<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.ml.mldj.system.mapper.SysUserMapper">

    <insert id="updateUserRole">
        insert into mailang.sys_user_role(role_id, user_id) VALUES
            <foreach collection="roleIds" item="id" close=")" open="(" separator=",">
                #{userId},#{id}
            </foreach>
    </insert>
    <delete id="delUserRole">
        delete from mailang.sys_user_role where user_id=#{userId}
    </delete>
</mapper>
